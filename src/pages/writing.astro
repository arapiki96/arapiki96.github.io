---
import BaseLayout from "../layouts/baselayout.astro";
import { getCollection } from "astro:content";
import { BEATS } from "../content.config";
import { formatDate } from "../lib/dateUtils";

const workItems = (await getCollection("work")).map((e) => e.data);
const politicsItems = (await getCollection("politics")).map((e) => e.data);

// "Now" and "Before" both newest-first by date.
const bd = [...workItems].sort((a, b) => b.date.valueOf() - a.date.valueOf());
const pol = [...politicsItems].sort((a, b) => b.date.valueOf() - a.date.valueOf());

// Topic-chip counts across both sections; only show beats that are in use.
const all = [...workItems, ...politicsItems];
const counts = Object.fromEntries(
  BEATS.map((b) => [b, all.filter((x) => x.beat === b).length]),
);
const beats = BEATS.filter((b) => counts[b] > 0);
---

<BaseLayout title="Work" description="Selected reporting and writing by Thomas Manch.">
  <div class="index-page">
    <h1>My work</h1>
    <p class="lede">
      I write a lot of news. Here is a sample of my reporting.</p>

    <div class="topic-filter">
      <div class="topic-filter__label">Filter by topic</div>
      <div class="topic-filter__chips">
        <button class="topic-chip" type="button" data-beat="All" aria-pressed="true">All <span class="topic-chip__count">{all.length}</span></button>
        {beats.map((b) => (
          <button class="topic-chip" type="button" data-beat={b} aria-pressed="false">{b} <span class="topic-chip__count">{counts[b]}</span></button>
        ))}
      </div>
    </div>

    <section class="work-section" data-section>
      <div class="work-eyebrow work-eyebrow--now">Now</div>
      <h2>Selected BusinessDesk reporting</h2>
      {bd.map((item) => (
        <a class="work-item" data-beat={item.beat} href={item.url} target="_blank" rel="noopener noreferrer">
          <span class="work-item__title">{item.title}</span>
          <span class="work-item__meta">{formatDate(item.date)}</span>
        </a>
      ))}
    </section>

    <section class="work-section" data-section>
      <div class="work-eyebrow">Before</div>
      <h2>Earlier reporting at The Post &amp; Stuff</h2>
      {pol.map((item) => (
        <a class="work-item" data-beat={item.beat} href={item.url} target="_blank" rel="noopener noreferrer">
          <span class="work-item__title">{item.title}</span>
          <span class="work-item__meta">{item.outlet} · {item.date.getFullYear()}</span>
        </a>
      ))}
    </section>

    <p class="work-empty" hidden>No pieces tagged with this topic yet.</p>
  </div>
</BaseLayout>

<script>
  const chips = Array.from(document.querySelectorAll<HTMLButtonElement>(".topic-chip"));
  const items = Array.from(document.querySelectorAll<HTMLElement>(".work-item"));
  const sections = Array.from(document.querySelectorAll<HTMLElement>("[data-section]"));
  const empty = document.querySelector<HTMLElement>(".work-empty");

  function apply(beat: string) {
    items.forEach((el) => {
      el.hidden = beat !== "All" && el.dataset.beat !== beat;
    });
    sections.forEach((sec) => {
      const anyVisible = Array.from(sec.querySelectorAll<HTMLElement>(".work-item")).some((el) => !el.hidden);
      sec.hidden = !anyVisible;
    });
    if (empty) empty.hidden = items.some((el) => !el.hidden);
    chips.forEach((c) => c.setAttribute("aria-pressed", String(c.dataset.beat === beat)));
  }

  chips.forEach((c) => c.addEventListener("click", () => apply(c.dataset.beat!)));
</script>
