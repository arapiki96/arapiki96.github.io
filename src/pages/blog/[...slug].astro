---
import BaseLayout from "../../layouts/baselayout.astro";
import { getCollection } from "astro:content";
import { formatDate } from "../../lib/dateUtils";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).filter((p) => !p.data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug.replace(/\/index$/, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const description = post.data.description ?? undefined;
const publishedTime = post.data.date ?? undefined;
const displayDate = formatDate(post.data.date);
const { Content } = await post.render();
---

<BaseLayout
  title={post.data.title}
  description={description}
  ogType="article"
  publishedTime={publishedTime}
>
  <h1 class="post-title">{post.data.title}</h1>
  <p class="muted"><time datetime={post.data.date.toISOString()}>{displayDate}</time></p>
  <Content />
</BaseLayout>
